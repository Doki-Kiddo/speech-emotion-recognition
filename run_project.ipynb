{
 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# Speech Emotion Recognition Project\n",
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1. Environment Check\n",
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "facd5cc4",
   "metadata": {},
   "outputs": [],
   "source": [
    "import os\n",
    "import sys\n",
    "from pathlib import Path\n",
    "\n",
    "PROJECT_ROOT = Path.cwd()\n",
    "print(\"Project root:\", PROJECT_ROOT)\n",
    "print(\"Python:\", sys.executable)\n",
    "\n",
    "if PROJECT_ROOT.name != \"speech-emotion-cnn\":\n",
    "    raise RuntimeError(\"Open this notebook from the speech-emotion-cnn project folder.\")\n",
    "\n",
    "required = [\"backend\", \"frontend\", \"src\", \"models\", \"data\"]\n",
    "missing = [name for name in required if not (PROJECT_ROOT / name).exists()]\n",
    "if missing:\n",
    "    raise RuntimeError(f\"Missing project folders: {missing}\")\n",
    "\n",
    "if \".venv\" not in sys.executable:\n",
    "    print(\"WARNING: This notebook is not using the project .venv kernel.\")\n",
    "    print(\"Go to Kernel -> Change kernel -> Python (.venv speech-emotion-cnn), then restart.\")\n",
    "else:\n",
    "    print(\"Using project .venv kernel.\")\n"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. Model Files\n",
    "\n",
    "This checks that the trained model and label file exist.\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "3a777492",
   "metadata": {},
   "outputs": [],
   "source": [
    "from pathlib import Path\n",
    "import json\n",
    "\n",
    "from src.config import MODEL_PATH, LABELS_PATH\n",
    "\n",
    "model_path = Path(MODEL_PATH)\n",
    "labels_path = Path(LABELS_PATH)\n",
    "print(\"Model exists:\", model_path.exists(), model_path)\n",
    "print(\"Labels exist:\", labels_path.exists(), labels_path)\n",
    "\n",
    "if not model_path.exists() or not labels_path.exists():\n",
    "    raise RuntimeError(\"Model files are missing. Set TRAIN_MODEL = True in the next cell and run it.\")\n",
    "\n",
    "labels = json.loads(labels_path.read_text(encoding=\"utf-8\"))\n",
    "print(\"Labels:\", labels)\n"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3. Training\n",
    "\n",
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "697173b8",
   "metadata": {},
   "outputs": [],
   "source": [
    "import subprocess\n",
    "import sys\n",
    "\n",
    "TRAIN_MODEL = False\n",
    "\n",
    "if TRAIN_MODEL:\n",
    "    result = subprocess.run([\n",
    "        sys.executable,\n",
    "        'train.py',\n",
    "        '--data-dir', 'data/raw',\n",
    "        '--epochs', '40',\n",
    "        '--batch-size', '32',\n",
    "    ], check=True)\n",
    "else:\n",
    "    print('Skipping training. Set TRAIN_MODEL = True to retrain.')\n"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4. Evaluation Report\n",
    "\n",
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "cb451f6b",
   "metadata": {},
   "outputs": [],
   "source": [
    "import os\n",
    "import subprocess\n",
    "import sys\n",
    "\n",
    "env = os.environ.copy()\n",
    "env['TF_CPP_MIN_LOG_LEVEL'] = '2'\n",
    "\n",
    "result = subprocess.run([\n",
    "    sys.executable,\n",
    "    'evaluate.py',\n",
    "    '--data-dir', 'data/raw',\n",
    "    '--split', 'validation',\n",
    "    '--test-size', '0.2',\n",
    "    '--seed', '42',\n",
    "    '--report-only',\n",
    "], check=True, capture_output=True, text=True, env=env)\n",
    "\n",
    "print(result.stdout)\n"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 5. Start Web App\n",
    "\n",
    "This starts the app at `http://127.0.0.1:5050`. The cell keeps running while the app is active. Interrupt the cell to stop the server.\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "1f408dbf",
   "metadata": {},
   "outputs": [],
   "source": [
    "from backend.app import app, warmup\n",
    "\n",
    "PORT = 5050\n",
    "print(\"Warming model first...\")\n",
    "warmup()\n",
    "\n",
    "print(f\"Starting app at http://127.0.0.1:{PORT}\")\n",
    "app.run(host=\"127.0.0.1\", port=PORT, debug=False, use_reloader=False, threaded=True)\n"
   ]
  }
 ],
